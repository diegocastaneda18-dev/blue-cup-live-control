# Root
NODE_ENV=development

# Postgres (docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bluecup
POSTGRES_USER=bluecup
POSTGRES_PASSWORD=bluecup_password

# API
API_PORT=4000
DATABASE_URL=postgresql://bluecup:bluecup_password@localhost:5432/bluecup?schema=public
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL_SECONDS=1209600

# --- Local dev: MinIO (docker compose -f infra/docker/docker-compose.yml up -d minio) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=bluecup_minio
S3_SECRET_KEY=bluecup_minio_secret
S3_BUCKET=bluecup-media
S3_PUBLIC_BASE_URL=http://localhost:9000/bluecup-media
S3_FORCE_PATH_STYLE=true

# --- Production: Cloudflare R2 (Railway API service) ---
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=<R2_ACCESS_KEY_ID>
# S3_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
# S3_BUCKET=bluecup-media
# S3_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
#   OR custom domain, e.g. https://media.yourdomain.com
# S3_FORCE_PATH_STYLE=false
# CORS: apply infra/r2/cors.json in R2 bucket settings (Settings → CORS policy)

# Upload limits (bytes) — defaults: photo 25MB, video 512MB, part 8MB
# S3_PHOTO_MAX_BYTES=26214400
# S3_VIDEO_MAX_BYTES=536870912
# S3_MULTIPART_PART_BYTES=8388608

# Websocket / CORS
WEB_ORIGIN_PARTICIPANT=http://localhost:3000
WEB_ORIGIN_ADMIN=http://localhost:3001
WEB_ORIGIN_PUBLIC=http://localhost:3002

# Next.js apps (admin, public, participant, web): show demo ribbon + sample data when API is empty
# NEXT_PUBLIC_BLUECUP_DEMO=true
# NEXT_PUBLIC_DEMO_MODE=true

# Web (Vercel)
# NEXT_PUBLIC_API_BASE_URL=https://your-api.railway.app
