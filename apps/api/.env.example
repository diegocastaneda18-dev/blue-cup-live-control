# Blue Cup API — copy to `.env` in this directory (or load via your host).

# --- Node ---
# `production` in deployed environments
NODE_ENV=development

# --- HTTP ---
API_PORT=4000

# --- Operational mode (logged at startup; extend with APP_MODE-aware code as needed) ---
APP_MODE=development

# --- Database (Prisma) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bluecup?schema=public"

# --- JWT access tokens (use strong secrets in production) ---
JWT_ACCESS_SECRET=change_me_in_production
JWT_ACCESS_TTL_SECONDS=900

# --- Las Marías Experience — local JSON fallback (default) ---
EXPERIENCE_STORAGE_DRIVER=file
ADMIN_AUTH_MODE=password
ADMIN_ACCESS_PASSWORD=admin123
EXPERIENCE_WEB_BASE_URL=http://localhost:3003
EXPERIENCE_EMAIL_ENABLED=false
# EXPERIENCE_EMAIL_FROM="Las Marías <noreply@example.com>"
# EXPERIENCE_EMAIL_INTERNAL_TO=ops@example.com
# RESEND_API_KEY=

# --- Las Marías Experience — Supabase staging (copy block to .env.local) ---
# EXPERIENCE_STORAGE_DRIVER=supabase
# ADMIN_AUTH_MODE=password
# ADMIN_ACCESS_PASSWORD=admin123
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# EXPERIENCE_EMAIL_ENABLED=false
#
# See apps/api/.env.local.example and docs/experience-supabase-staging-checklist.md

# --- Supabase Auth (later — after staging DB+Storage validated) ---
# ADMIN_AUTH_MODE=supabase
