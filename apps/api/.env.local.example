# Las Marías Experience — Supabase staging (API)
# Copy to apps/api/.env.local and fill Supabase credentials.
# .env.local overrides .env (see ConfigModule in app.module.ts).

EXPERIENCE_STORAGE_DRIVER=supabase
ADMIN_AUTH_MODE=password
ADMIN_ACCESS_PASSWORD=admin123

# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

EXPERIENCE_WEB_BASE_URL=http://localhost:3003
EXPERIENCE_EMAIL_ENABLED=false

# Keep Prisma / other Blue Cup vars in apps/api/.env if needed:
# PORT=4000
# DATABASE_URL=...
