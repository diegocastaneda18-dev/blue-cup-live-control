# Blue Cup web — copy to `.env.local` in this directory for local dev.
# `NEXT_PUBLIC_*` values are inlined at `next build`; set them in CI and hosting too.

# --- Required: API origin (no trailing slash) ---
# Local example points at the Nest app; production: your deployed API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Application mode (`development` | `production`) ---
# Optional: when unset, mode follows Next.js NODE_ENV (dev server vs production build).
NEXT_PUBLIC_APP_MODE=development

# --- Demo mode (`true` | `false`) ---
# When true: shows a global demo ribbon and fills empty API lists with sample tournaments, teams,
# catches, leaderboard, and committee queue (see @bluecup/types demo fixtures). Admins get “Reset demo data” on the dashboard.
NEXT_PUBLIC_BLUECUP_DEMO=false
# Alias (either can enable demo):
NEXT_PUBLIC_DEMO_MODE=false
